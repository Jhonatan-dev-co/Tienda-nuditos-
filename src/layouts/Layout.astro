---
import '../styles/global.css';

const { title, description } = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-[#fdf8f5] text-[#2c1810] font-lato">

    <!-- HEADER MÓVIL -->
    <header class="fixed top-0 w-full bg-[#fdf8f5]/95 backdrop-blur-sm z-50 border-b border-[#e8d5c4]">
      <div class="px-4 py-3 flex items-center justify-between">
        <a href="/" class="font-playfair text-xl font-semibold text-[#8b4513]">Nuditos 🌸</a>
        <div class="flex items-center gap-3">
          <a href="/tienda" class="bg-[#8b4513] text-white px-4 py-1.5 rounded-full text-xs font-semibold">
            Tienda
          </a>
        </div>
      </div>
    </header>

    <!-- CONTENIDO PRINCIPAL -->
    <slot />

  </body>
</html>